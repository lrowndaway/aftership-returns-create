# AfterShip Returns API — Create Return
# https://www.aftership.com/docs/returns/quickstart/api-quick-start
AFTERSHIP_API_KEY=your_aftership_returns_api_key
AFTERSHIP_RETURNS_API_VERSION=2026-01

# Shopify store external id as configured in AfterShip Returns (often subdomain of myshopify.com).
# Leave blank to derive from SHOPIFY_SHOP_DOMAIN (subdomain before .myshopify.com).
AFTERSHIP_STORE_EXTERNAL_ID=

# Shopify Admin API — used to fetch order + line items before POST /returns
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=your_shopify_admin_api_access_token
SHOPIFY_API_VERSION=2024-10

# Defaults for the create-return body (override with CLI flags if needed)
AFTERSHIP_DEFAULT_REFUND_DESTINATION=original_payment
AFTERSHIP_DEFAULT_RETURN_METHOD_TYPE=retailer_label
